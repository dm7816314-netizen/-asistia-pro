# Copia este archivo como .env.local para desarrollo local
# En Vercel, agrega estas variables en: Settings → Environment Variables

# OBLIGATORIO: Tu API Key de Anthropic (consíguela en console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxx

# OPCIONAL: Instrucciones personalizadas para el asistente
ASSISTANT_PROMPT=Eres el asistente administrativo de [NOMBRE DE TU NEGOCIO]. Responde siempre en español, de forma amable y profesional. Horarios: [TUS HORARIOS]. Servicios: [TUS SERVICIOS].

# OPCIONAL: Tu correo para recibir notificaciones de nuevas suscripciones
ADMIN_EMAIL=tu@correo.cl

# OPCIONAL: API Key de Resend para notificaciones por email (resend.com - gratis hasta 3.000/mes)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxx
